---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Dale Media', description = 'ビジネスに役立つAI情報メディア' } = Astro.props;
const siteTitle = title === 'Dale Media' ? title : `${title} | Dale Media`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{siteTitle}</title>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="logo">Dale Media</a>
        <nav>
          <a href="/ai-basics">AI入門</a>
          <a href="/biz-ai">ビジネスAI</a>
          <a href="/cases">事例</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} Dale Media</p>
    </footer>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    font-family: 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
    color: #1a1a1a;
    background: #fafafa;
    line-height: 1.7;
  }

  header {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.4rem;
    font-weight: 700;
    text-decoration: none;
    color: #1a1a1a;
    letter-spacing: -0.02em;
  }

  nav {
    display: flex;
    gap: 2rem;
  }

  nav a {
    text-decoration: none;
    color: #4b5563;
    font-size: 0.95rem;
    transition: color 0.15s;
  }

  nav a:hover {
    color: #1a1a1a;
  }

  main {
    min-height: calc(100vh - 120px);
  }

  footer {
    text-align: center;
    padding: 2rem;
    color: #9ca3af;
    font-size: 0.875rem;
    border-top: 1px solid #e5e7eb;
  }
</style>
